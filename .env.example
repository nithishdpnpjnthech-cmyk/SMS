# ============================================================
# SMS ACADEMY — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# On AWS: set these in EC2 env variables or Secrets Manager.
# ============================================================

# App
NODE_ENV=production
PORT=5051

# ── MySQL Database (AWS RDS) ─────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=your-db-password-here
DB_NAME=sms
DB_PORT=3306

# ── Razorpay Payment Gateway ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# ── Email (Gmail App Password recommended) ───────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── SMS Gateway (Fast2SMS) ───────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-api-key

# ── Session Secret (use a long random string) ────────────────
SESSION_SECRET=change-this-to-a-long-random-secret-string

# ── Production Domain (your AWS public URL or custom domain) ──
ALLOWED_ORIGIN=https://yourdomain.com
